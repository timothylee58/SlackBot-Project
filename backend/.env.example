# Slack Bot Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=your-slack-channel-id

# Singapore LTA DataMall (traffic data)
LTA_ACCOUNT_KEY=your-lta-account-key

# Public URL of your deployed server (used in Slack map link)
BASE_URL=https://your-app.onrender.com

# Google Maps JavaScript API key (enable "Maps JavaScript API" in Google Cloud Console)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OpenWeatherMap API key (for cloud/precipitation overlay tiles)
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Optional: override default port (default: 3000)
# PORT=3000
